# Copy this file to .env.local and fill in your values
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/ai_todo

# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# Mobile Google sign-in — the iOS/Android/Web OAuth client IDs the Expo app uses.
# Comma-separated; the /api/auth/mobile/google endpoint accepts these token audiences.
GOOGLE_MOBILE_CLIENT_IDS=ios_client_id,android_client_id,web_client_id

# SEO — production origin used for canonical URLs, Open Graph images, robots, and
# the sitemap. MUST be the absolute public URL in production (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# SEO — Google Search Console verification token (Settings → Ownership
# verification → HTML tag → copy the content="..." value). Optional.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Maps — create an API key at https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Maps JavaScript API, Places API (New), Geocoding API
# Optional — without it, todo locations fall back to plain text (no map / autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
